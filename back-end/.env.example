# ===========================
# Variables de Entorno
# ===========================

# Puerto de la API
API_PORT=5000

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tu_contraseña
DB_NAME=nuestro_bienestar

# Super Usuario (credenciales iniciales para el seeder)
SUPER_USER_NOMBRE=Super Admin
SUPER_USER_CORREO=superadmin@bienestar.com
SUPER_USER_CONTRASENA=Admin123456

# JWT (genera una clave segura con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=tu_clave_secreta_aqui_cambiarla_en_produccion
JWT_SECRET_ACCESS=tu_clave_secreta_access_aqui_cambiarla
JWT_SECRET_REFRESH=tu_clave_secreta_refresh_aqui_cambiarla
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Socket IO
SOCKET_PORT=5001

# Entorno
NODE_ENV=development

# CORS - URLs permitidas (separadas por coma para múltiples)
CORS_ORIGIN=http://localhost:4200,http://localhost:3000

# AWS (si usas AWS)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=tu_access_key
AWS_SECRET_ACCESS_KEY=tu_secret_key
